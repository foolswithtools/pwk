# Grafana Cloud Configuration
# Copy this file to .env and fill in your Grafana Cloud credentials

# ============================================================================
# OTLP Configuration (for GPWK telemetry - traces, metrics, logs)
# ============================================================================

# OTLP Endpoint (from Grafana Cloud → Connections → OpenTelemetry)
# Example: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_ENDPOINT=

# OTLP Username (might be Stack ID, Org ID, or Instance ID - check OTLP connection docs)
# This is the username shown in Grafana Cloud → Connections → OpenTelemetry
# Example: 123456 or your-stack-name
GRAFANA_CLOUD_OTLP_USERNAME=

# ============================================================================
# Prometheus Configuration (for Alloy meta-monitoring)
# ============================================================================

# Prometheus Remote Write Endpoint (from Grafana Cloud → Prometheus → Details)
# Example: https://prometheus-prod-01-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_URL=

# Prometheus Username (from Grafana Cloud → Prometheus → Details)
# This is your Prometheus instance username
# Example: 2731165
GRAFANA_CLOUD_PROMETHEUS_USERNAME=

# ============================================================================
# API Key (shared by both OTLP and Prometheus)
# ============================================================================

# Grafana Cloud API Key (create with metrics:write, logs:write, traces:write scopes)
# Go to: My Account → Cloud Portal → Access Policies → Create Access Policy
# Example: glc_eyJrIjoiYWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXowMTIzNDU2Nzg5IiwibCI6InN0YWNrLTEyMzQ1Ni11cy1lYXN0LTAiLCJuIjoibXktYXBpLWtleSJ9
GRAFANA_CLOUD_API_KEY=
