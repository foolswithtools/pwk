#!/usr/bin/env bash
# Wrapper script to activate venv and run Python

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VENV_PYTHON="$SCRIPT_DIR/../lib/python/venv/bin/python3"

# Check if venv exists
if [ ! -f "$VENV_PYTHON" ]; then
    echo "Error: Virtual environment not found at $VENV_PYTHON" >&2
    echo "Run: cd gpwk/lib/python && python3 -m venv venv && pip install -r requirements.txt" >&2
    exit 1
fi

# Execute Python CLI module directly
exec "$VENV_PYTHON" -m gpwk_core.cli.carryover_cli "$@"
